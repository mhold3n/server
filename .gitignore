!**/config/*.yaml
!**/config/*.yml
!**/docker-compose*.yml
!**/docker-compose*.yaml
# Observability stack configs (normally ignored by *.yml / *.yaml above)
!infra/observability/**/*.yml
!infra/observability/**/*.yaml
# TypeScript/npm workspace for agent-platform (normally ignored by *.json above)
!services/agent-platform/**/*.json
!/package.json
!/package-lock.json
# Structure schemas, registries, and policies are source files, not generated artifacts
!services/structure/schemas/**/*.json
!services/structure/registry/**/*.json
# Monorepo JSON Schema contracts (control-plane + model-runtime registries and fixtures)
!schemas/control-plane/**/*.json
!schemas/model-runtime/**/*.json
# Response-control catalogs are source inputs for mode/pool/module selection.
!knowledge/response-control/**/*.json
# Coding-tool knowledge artifacts are repo-native source data for the knowledge pool.
!knowledge/coding-tools/**/*.json
knowledge/coding-tools/runtime/dotnet/**/bin/
knowledge/coding-tools/runtime/dotnet/**/obj/
!services/structure/policies/**/*.yaml

