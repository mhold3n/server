// Example fragment for ~/.openclaw/openclaw.json (JSON5-style comments ok in OpenClaw config).
// 1. Start MBMH: mbmh/.venv/bin/python scripts/serve_local.py --config configs/runtime/openai-compatible.yaml
// 2. Confirm: curl -sS http://127.0.0.1:8000/v1/models -H "Authorization: Bearer sk-local-dev-001"
// 3. Merge this under top-level keys; set agents.defaults.model.primary to "mbmh-local/openclaw-agent" (or your model id).

{
  models: {
    mode: "merge",
    providers: {
      mbmh-local: {
        baseUrl: "http://127.0.0.1:8000/v1",
        apiKey: "sk-local-dev-001",
        // Chat Completions only — NOT openai-responses (MBMH has no /v1/responses).
        api: "openai-completions",
        models: [
          {
            id: "openclaw-agent",
            name: "MBMH openclaw-agent",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            // OpenClaw logs "low context window" if contextWindow < 32000 (agent/embedded warn).
            contextWindow: 32768,
            maxTokens: 8192,
          },
        ],
      },
    },
  },
  agents: {
    defaults: {
      model: { primary: "mbmh-local/openclaw-agent" },
    },
  },
}
