// Example fragment for ~/.openclaw/openclaw.json (merge under top-level keys).
// Goal: least-privilege OpenClaw + Bitwarden Secrets Manager automation (machine account).
// Validate after merge: openclaw config validate
//
// 1) Gateway: loopback + token auth (adjust token; prefer ${OPENCLAW_GATEWAY_TOKEN} in real config).
// 2) tools.allow: only tool bundles/plugins this deployment needs (add birtha-devplane, etc.).
// 3) skills.allowBundled: optional strict allowlist of ClawHub/bundled skills (omit to use defaults).
// 4) Bitwarden SM: use bws.env + sync-skill-secrets.py; see SKILLS-SETUP.md. For community
//    BWS skills, source source-bws-hal-aliases.sh after bws.env.
//
// Official references:
// - https://docs.openclaw.ai/gateway/configuration
// - https://docs.openclaw.ai/tools/skills-config

{
  gateway: {
    bind: "loopback",
    auth: {
      mode: "token",
      // Prefer env substitution in your real file, e.g. token: "${OPENCLAW_GATEWAY_TOKEN}",
      token: "replace-with-long-random-token",
    },
  },

  tools: {
    // Whitelist named tool bundles the agent may use. Tune to your install (see `openclaw doctor` / docs).
    profile: "coding",
    allow: ["birtha-devplane"],
  },

  skills: {
    // Strict subset of bundled skills; restart gateway after edits.
    allowBundled: ["github", "gh-issues", "healthcheck", "skill-creator", "weather"],
  },
}
