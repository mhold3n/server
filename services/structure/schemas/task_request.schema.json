{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "task_request.schema.json",
    "title": "TaskRequest",
    "description": "Incoming task request from LLM or user",
    "type": "object",
    "properties": {
        "request_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique request identifier for tracing"
        },
        "user_input": {
            "type": "string",
            "minLength": 1,
            "description": "The user's natural language input"
        },
        "project_id": {
            "type": "string",
            "description": "Optional registered development-plane project identifier"
        },
        "domain_hint": {
            "type": "string",
            "description": "Optional domain hint to guide routing"
        },
        "repo_ref_hint": {
            "type": "string",
            "description": "Optional repository path, branch, or subsystem hint"
        },
        "risk_hints": {
            "type": "array",
            "description": "Optional operator-provided risk hints for the task",
            "items": {
                "type": "string"
            }
        },
        "constraints": {
            "type": "array",
            "description": "Optional human-specified constraints for the task",
            "items": {
                "type": "string"
            }
        },
        "acceptance_criteria": {
            "type": "array",
            "description": "Optional success criteria supplied at intake time",
            "items": {
                "type": "string"
            }
        },
        "context": {
            "type": "object",
            "description": "Additional context from previous turns",
            "additionalProperties": true
        },
        "session_id": {
            "type": "string",
            "format": "uuid",
            "description": "Session identifier for multi-turn conversations"
        }
    },
    "required": [
        "user_input"
    ]
}
