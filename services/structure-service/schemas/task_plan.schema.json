{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "task_plan.schema.json",
    "title": "TaskPlan",
    "description": "Router output - deterministic task classification",
    "type": "object",
    "properties": {
        "domain": {
            "type": "string",
            "enum": [
                "physics",
                "chemistry",
                "math",
                "code",
                "general",
                "experiment",
                "survey",
                "project",
                "operations",
                "analysis"
            ],
            "description": "Primary domain classification"
        },
        "project_id": {
            "type": "string",
            "description": "Optional registered development-plane project identifier"
        },
        "objective": {
            "type": "string",
            "description": "Normalized delivery objective for the task"
        },
        "constraints": {
            "type": "array",
            "description": "Constraints gathered from intake and clarification",
            "items": {
                "type": "string"
            }
        },
        "acceptance_criteria": {
            "type": "array",
            "description": "Conditions required for successful completion",
            "items": {
                "type": "string"
            }
        },
        "implementation_outline": {
            "type": "array",
            "description": "High-level implementation stages for the task",
            "items": {
                "type": "string"
            }
        },
        "delegation_hints": {
            "type": "array",
            "description": "Optional hints about how the lead executor may delegate focused subtasks",
            "items": {
                "type": "string"
            }
        },
        "work_items": {
            "type": "array",
            "description": "Optional normalized work-item checklist for the internal task-agent runtime",
            "items": {
                "type": "string"
            }
        },
        "verification_plan": {
            "type": "array",
            "description": "Verification commands or checks that should be run",
            "items": {
                "type": "string"
            }
        },
        "verification_blocks": {
            "type": "array",
            "description": "Explicit structured verification commands for execution handoff",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "command": {
                        "type": "string"
                    },
                    "required": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "name",
                    "command"
                ],
                "additionalProperties": false
            }
        },
        "publish_intent": {
            "type": "object",
            "description": "Desired publish or delivery mode for the task",
            "properties": {
                "mode": {
                    "type": "string"
                },
                "push": {
                    "type": "boolean"
                },
                "create_pr": {
                    "type": "boolean"
                },
                "remote_name": {
                    "type": "string"
                }
            },
            "additionalProperties": true
        },
        "planned_branch": {
            "type": "string",
            "description": "Preferred branch name for an isolated task workspace"
        },
        "subdomain": {
            "type": "string",
            "description": "Subdomain within primary domain (e.g., fluids, mechanics)"
        },
        "needs_units": {
            "type": "boolean",
            "description": "Whether the task involves physical units"
        },
        "has_equations": {
            "type": "boolean",
            "description": "Whether equations were detected in input"
        },
        "risk_level": {
            "type": "string",
            "enum": [
                "low",
                "medium",
                "high"
            ],
            "description": "Risk level for ambiguity/error"
        },
        "required_gates": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Gate IDs that must be run"
        },
        "selected_kernels": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Kernel IDs selected for execution"
        },
        "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Classification confidence"
        }
    },
    "required": [
        "domain",
        "required_gates"
    ]
}
