{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.dev/schemas/openclaw-bridge/v1/tool-model/tool-query-response.schema.json",
  "title": "ToolQueryResponse",
  "oneOf": [
    { "$ref": "#/$defs/tool_result_structured" },
    { "$ref": "#/$defs/tool_result_untrusted_text" },
    { "$ref": "#/$defs/tool_result_needs_governed_escalation" },
    { "$ref": "#/$defs/tool_result_rejected" }
  ],
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin",
        "tool_name",
        "tool_call_id",
        "model_used",
        "lane",
        "confidence_mode",
        "mutation_rights",
        "authoritative",
        "requires_validation"
      ],
      "properties": {
        "origin": { "const": "openclaw_tool" },
        "tool_name": { "type": "string", "minLength": 1 },
        "tool_call_id": { "type": "string", "minLength": 1 },
        "model_used": { "type": "string", "minLength": 1 },
        "lane": { "const": "tool_model" },
        "confidence_mode": { "const": "preliminary" },
        "mutation_rights": { "const": "none" },
        "authoritative": { "const": false },
        "requires_validation": { "const": true }
      }
    },
    "tool_result_structured": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_type", "provenance", "payload"],
      "properties": {
        "result_type": { "const": "tool_result_structured" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "payload": { "type": "object" }
      }
    },
    "tool_result_untrusted_text": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_type", "provenance", "text"],
      "properties": {
        "result_type": { "const": "tool_result_untrusted_text" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "text": { "type": "string" }
      }
    },
    "tool_result_needs_governed_escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_type", "reason_code", "handoff_hint"],
      "properties": {
        "result_type": { "const": "tool_result_needs_governed_escalation" },
        "reason_code": {
          "type": "string",
          "enum": [
            "policy_requires_governed_run",
            "model_refused",
            "insufficient_context",
            "schema_unreachable",
            "internal"
          ]
        },
        "handoff_hint": {
          "type": "object",
          "description": "Minimal payload for POST /api/ai/query or workflow trigger — no governed IDs invented here.",
          "additionalProperties": true
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "tool_result_rejected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_type", "error_code", "message"],
      "properties": {
        "result_type": { "const": "tool_result_rejected" },
        "error_code": {
          "type": "string",
          "enum": [
            "unknown_tool",
            "tool_class_forbidden",
            "schema_validation_failed",
            "policy_denied",
            "payload_too_large",
            "unauthorized"
          ]
        },
        "message": { "type": "string" },
        "detail": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
