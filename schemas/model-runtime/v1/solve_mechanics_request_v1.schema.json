{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/model-runtime/v1/solve_mechanics_request_v1.schema.json",
  "title": "solve_mechanics_request_v1",
  "description": "For agents: POST /solve/mechanics body; must match engineering_core.solve_mechanics expectations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assumption_profile_id",
    "assumption_overrides",
    "geometry",
    "block_material_id",
    "surface_material_id",
    "fluid_id",
    "applied_force_N",
    "force_direction_assumption",
    "displacement_m"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "assumption_profile_id": {
      "type": "string",
      "const": "RIGID_BLOCK_DRY_SLIDING_V1"
    },
    "assumption_overrides": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fluid_id", "viscous_enabled"],
      "properties": {
        "fluid_id": { "type": ["string", "null"] },
        "viscous_enabled": { "type": "boolean" }
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "cube_side_m"],
      "properties": {
        "shape": { "type": "string", "const": "CUBE" },
        "cube_side_m": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "block_material_id": { "type": "string" },
    "surface_material_id": { "type": "string" },
    "fluid_id": { "type": ["string", "null"] },
    "applied_force_N": { "type": "number" },
    "force_direction_assumption": {
      "type": "string",
      "const": "horizontal_in_plane"
    },
    "displacement_m": { "type": "number", "exclusiveMinimum": 0 }
  }
}
