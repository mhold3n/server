{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/model-runtime/v1/engineering_report_v1.schema.json",
  "title": "Engineering report v1",
  "description": "Deterministic solver output; primary artifact for v1 mechanics harness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "problem_brief",
    "assumptions",
    "inputs",
    "derived_quantities",
    "results",
    "energy_balance",
    "model_limits",
    "comparison_case"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "problem_brief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "derived_quantities": {
      "type": "object",
      "additionalProperties": true
    },
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceleration_mps2",
        "normal_force_N",
        "reaction_force_N",
        "resisting_force_N",
        "heat_dissipation_J"
      ],
      "properties": {
        "acceleration_mps2": { "type": "number" },
        "normal_force_N": { "type": "number" },
        "reaction_force_N": { "type": "number" },
        "resisting_force_N": { "type": "number" },
        "heat_dissipation_J": { "type": "number" }
      }
    },
    "energy_balance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_in_J",
        "kinetic_energy_change_J",
        "dissipated_J",
        "residual_J"
      ],
      "properties": {
        "work_in_J": { "type": "number" },
        "kinetic_energy_change_J": { "type": "number" },
        "dissipated_J": { "type": "number" },
        "residual_J": { "type": "number" }
      }
    },
    "model_limits": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "comparison_case": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
