{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/model-runtime/v1/model_runtime_response.schema.json",
  "title": "Model runtime inference response",
  "description": "Unified envelope for POST /infer/general | coding | multimodal.",
  "type": "object",
  "additionalProperties": false,
  "required": ["usage", "model_id_resolved"],
  "properties": {
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_tokens", "completion_tokens", "latency_ms"],
      "properties": {
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "latency_ms": { "type": "number", "minimum": 0 }
      }
    },
    "model_id_resolved": {
      "type": "string",
      "minLength": 1
    },
    "text": { "type": "string" },
    "structured_output": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
