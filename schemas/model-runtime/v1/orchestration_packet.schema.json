{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/model-runtime/v1/orchestration_packet.schema.json",
  "title": "orchestration_packet — model-runtime /infer/general body",
  "description": "For agents: packet_class must be ORCHESTRATION. Runtime enforces parent_packet_id vs workflow_root query param.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "packet_class",
    "operation",
    "objective",
    "context_summary",
    "constraints",
    "expected_output",
    "routing_metadata",
    "provenance"
  ],
  "properties": {
    "packet_id": {
      "$ref": "https://birtha.local/schemas/model-runtime/v1/mr-common.schema.json#/$defs/uuidString"
    },
    "packet_class": {
      "type": "string",
      "const": "ORCHESTRATION"
    },
    "operation": {
      "type": "string",
      "enum": ["INTAKE", "SYNTHESIZE", "MAP", "VERIFY", "OTHER"]
    },
    "objective": { "type": "string" },
    "context_summary": { "type": "string" },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "schema_id", "cardinality", "allow_partial"],
      "properties": {
        "artifact_type": { "type": "string" },
        "schema_id": { "type": "string" },
        "cardinality": {
          "type": "string",
          "enum": ["ONE", "MANY", "ZERO_OR_ONE"]
        },
        "allow_partial": { "type": "boolean" }
      }
    },
    "routing_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_executor",
        "selection_reason_code",
        "selection_reason_detail",
        "policy_version",
        "budget_policy"
      ],
      "properties": {
        "selected_executor": { "type": "string" },
        "selection_reason_code": { "type": "string" },
        "selection_reason_detail": { "type": "string" },
        "policy_version": { "type": "string" },
        "budget_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allow_escalation"],
          "properties": {
            "allow_escalation": { "type": "boolean" },
            "max_tokens": { "type": "integer", "minimum": 0 },
            "max_cost_usd": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_stage",
        "parent_packet_id",
        "input_artifact_refs",
        "decision_ref"
      ],
      "properties": {
        "source_stage": { "type": "string" },
        "parent_packet_id": {
          "anyOf": [
            {
              "$ref": "https://birtha.local/schemas/model-runtime/v1/mr-common.schema.json#/$defs/uuidString"
            },
            { "type": "null" }
          ]
        },
        "input_artifact_refs": {
          "type": "array",
          "items": {
            "$ref": "https://birtha.local/schemas/model-runtime/v1/mr-common.schema.json#/$defs/artifactRef"
          }
        },
        "decision_ref": { "type": ["string", "null"] }
      }
    }
  }
}
