{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/gui-session-spec.schema.json",
  "title": "gui_session_spec — containerized GUI control contract",
  "description": "For agents: direct link between a dockerized knowledge runtime and its headless noVNC/OpenClaw GUI control surface.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gui_session_spec_id",
    "schema_version",
    "base_environment_ref",
    "gui_environment_ref",
    "module_ids",
    "docker_image",
    "docker_platform",
    "display_protocol",
    "control_provider",
    "container_ports",
    "display_env",
    "launch_command",
    "healthcheck_command",
    "openclaw_entry_url",
    "artifact_output_dir",
    "security_policy",
    "manifest_path",
    "launcher_ref"
  ],
  "properties": {
    "gui_session_spec_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "base_environment_ref": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
    },
    "gui_environment_ref": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
    },
    "module_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
      }
    },
    "docker_image": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "docker_platform": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "display_protocol": {
      "type": "string",
      "const": "novnc_web"
    },
    "control_provider": {
      "type": "string",
      "const": "openclaw_browser"
    },
    "container_ports": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bind_host", "novnc", "vnc"],
      "properties": {
        "bind_host": {
          "type": "string",
          "const": "127.0.0.1"
        },
        "novnc": {
          "type": "integer",
          "minimum": 1
        },
        "vnc": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "display_env": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "minProperties": 1
    },
    "launch_command": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "healthcheck_command": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "openclaw_entry_url": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "artifact_output_dir": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "security_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bind_host",
        "require_token",
        "network_mode",
        "allow_host_desktop",
        "close_on_session_end"
      ],
      "properties": {
        "bind_host": {
          "type": "string",
          "const": "127.0.0.1"
        },
        "require_token": {
          "type": "boolean",
          "const": true
        },
        "network_mode": {
          "type": "string",
          "enum": ["bridge", "none"]
        },
        "allow_host_desktop": {
          "type": "boolean",
          "const": false
        },
        "close_on_session_end": {
          "type": "boolean"
        }
      }
    },
    "manifest_path": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "launcher_ref": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "app_profile": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "launch_target_command": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "verification_ref": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
