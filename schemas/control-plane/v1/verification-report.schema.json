{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/verification-report.schema.json",
  "title": "verification_report — gate outcomes + escalation recommendation",
  "description": "For agents: produced by verification plane after deterministic + policy checks. gate_results records per-gate machine outcomes; blocking_findings captures human-readable defects.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verification_report_id",
    "schema_version",
    "outcome",
    "recommended_next_action",
    "validated_artifact_refs",
    "created_at"
  ],
  "properties": {
    "verification_report_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/uuidString"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "outcome": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/verificationOutcomeEnum"
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity"],
        "properties": {
          "code": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "severity": {
            "type": "string",
            "pattern": "^(low|medium|high|critical)$"
          },
          "artifact_ref": { "type": ["string", "null"] }
        }
      }
    },
    "gate_results": {
      "type": "array",
      "description": "Per-gate outcomes; optional but recommended for auditable verification.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "gate_kind", "status"],
        "properties": {
          "gate_id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "gate_kind": {
            "type": "string",
            "enum": [
              "schema",
              "units",
              "numeric_sanity",
              "tests",
              "citations",
              "policy",
              "simulation",
              "custom"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["PASS", "FAIL", "SKIP", "ERROR"]
          },
          "detail": { "type": "string" },
          "remediation_hint": { "type": "string" },
          "artifact_ref": { "type": ["string", "null"] }
        }
      }
    },
    "recommended_next_action": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "suggested_executor": {
      "anyOf": [
        { "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/executorEnum" },
        { "type": "null" }
      ]
    },
    "validated_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "source_task_packet_id": {
      "anyOf": [
        {
          "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/uuidString"
        },
        { "type": "null" }
      ]
    },
    "created_at": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/iso8601Utc"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": { "enum": ["REWORK", "ESCALATE"] }
        },
        "required": ["outcome"]
      },
      "then": {
        "properties": {
          "blocking_findings": {
            "type": "array",
            "minItems": 1
          }
        },
        "required": ["blocking_findings"]
      }
    },
    {
      "if": {
        "properties": { "outcome": { "const": "ESCALATE" } },
        "required": ["outcome"]
      },
      "then": {
        "properties": {
          "recommended_next_action": { "const": "create_escalation_packet" }
        }
      }
    }
  ]
}
