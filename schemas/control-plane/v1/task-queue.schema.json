{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/task-queue.schema.json",
  "title": "task_queue — ordered work orders with dependencies and approvals",
  "description": "For agents: references task_packet artifacts by id; does not embed full packets. Control plane schedules items respecting depends_on and approval gates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_queue_id",
    "schema_version",
    "problem_brief_ref",
    "items",
    "queue_status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "task_queue_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/uuidString"
    },
    "schema_version": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/semverString"
    },
    "trace_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/traceId"
    },
    "problem_brief_ref": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
    },
    "engineering_state_ref": {
      "anyOf": [
        {
          "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
        },
        { "type": "null" }
      ]
    },
    "merge_policy_version": {
      "type": "string",
      "description": "Must match engineering_state.merge_policy_version when state is linked."
    },
    "queue_status": {
      "type": "string",
      "enum": ["OPEN", "DRAINING", "CLOSED", "CANCELLED"]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_packet_ref", "depends_on", "approval"],
        "properties": {
          "order_hint": { "type": "integer" },
          "task_packet_ref": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
          },
          "depends_on": {
            "type": "array",
            "description": "Other task_packet artifact refs that must complete first.",
            "items": {
              "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
            }
          },
          "approval": {
            "type": "object",
            "additionalProperties": false,
            "required": ["required", "status"],
            "properties": {
              "required": { "type": "boolean" },
              "status": {
                "type": "string",
                "enum": ["PENDING", "APPROVED", "REJECTED", "WAIVED"]
              },
              "approver": { "type": ["string", "null"] },
              "decided_at": {
                "type": ["string", "null"],
                "format": "date-time"
              }
            }
          },
          "aggregate_budget": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/budgetPolicyObject"
          }
        }
      }
    },
    "notes": { "type": "string" },
    "created_at": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/iso8601Utc"
    },
    "updated_at": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/iso8601Utc"
    }
  }
}
