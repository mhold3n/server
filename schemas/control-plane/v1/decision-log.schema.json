{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/decision-log.schema.json",
  "title": "decision_log — recorded stack choice and tradeoffs",
  "description": "For agents: the formal record that prevents the same stack selection arguments from being relitigated in every run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "schema_version",
    "title",
    "statement",
    "rationale",
    "chosen_refs",
    "rejected_refs",
    "tradeoffs",
    "status"
  ],
  "properties": {
    "decision_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "title": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "statement": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "rationale": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "chosen_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "rejected_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "tradeoffs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["accepted", "proposed", "superseded"]
    }
  }
}
