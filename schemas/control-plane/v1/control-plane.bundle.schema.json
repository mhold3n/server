{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/control-plane.bundle.schema.json",
  "title": "control_plane_bundle — discriminated ingress wrapper",
  "description": "For agents: optional API envelope when a single endpoint accepts multiple contract kinds. Prefer dedicated routes when possible.",
  "type": "object",
  "additionalProperties": false,
  "oneOf": [
    {
      "type": "object",
      "required": ["contract", "task_packet"],
      "properties": {
        "contract": { "const": "task_packet" },
        "task_packet": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/task-packet.schema.json"
        }
      }
    },
    {
      "type": "object",
      "required": ["contract", "problem_brief"],
      "properties": {
        "contract": { "const": "problem_brief" },
        "problem_brief": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/problem-brief.schema.json"
        }
      }
    },
    {
      "type": "object",
      "required": ["contract", "task_queue"],
      "properties": {
        "contract": { "const": "task_queue" },
        "task_queue": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/task-queue.schema.json"
        }
      }
    },
    {
      "type": "object",
      "required": ["contract", "engineering_state"],
      "properties": {
        "contract": { "const": "engineering_state" },
        "engineering_state": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/engineering-state.schema.json"
        }
      }
    },
    {
      "type": "object",
      "required": ["contract", "routing_policy"],
      "properties": {
        "contract": { "const": "routing_policy" },
        "routing_policy": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/routing-policy.schema.json"
        }
      }
    },
    {
      "type": "object",
      "required": ["contract", "verification_report"],
      "properties": {
        "contract": { "const": "verification_report" },
        "verification_report": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/verification-report.schema.json"
        }
      }
    },
    {
      "type": "object",
      "required": ["contract", "escalation_packet"],
      "properties": {
        "contract": { "const": "escalation_packet" },
        "escalation_packet": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/escalation-packet.schema.json"
        }
      }
    },
    {
      "type": "object",
      "required": ["contract", "response_control_assessment"],
      "properties": {
        "contract": { "const": "response_control_assessment" },
        "response_control_assessment": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/response-control-assessment.schema.json"
        }
      }
    },
    {
      "type": "object",
      "required": ["contract", "artifact_record"],
      "properties": {
        "contract": { "const": "artifact_record" },
        "artifact_record": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/artifact-record.schema.json"
        }
      }
    }
  ]
}
