{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/engineering-state.schema.json",
  "title": "engineering_state — canonical merged technical state",
  "description": "For agents: system-of-record for normalized engineering boundary, variables, verification intent, open issues, conflicts, and gates. Task decomposition must be blocked until ready_for_task_decomposition=true.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "engineering_state_id",
    "schema_version",
    "problem_brief_ref",
    "knowledge_candidate_refs",
    "knowledge_role_context_refs",
    "knowledge_gaps",
    "knowledge_required",
    "evidence_bundle_refs",
    "normalized_boundary",
    "objectives",
    "verification_intent",
    "variables",
    "constraints",
    "boundary_conditions",
    "unknowns",
    "assumption_status",
    "open_issues",
    "conflicts",
    "staleness",
    "required_gates",
    "ready_for_task_decomposition",
    "merge_policy_version",
    "updated_at"
  ],
  "properties": {
    "engineering_state_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/uuidString"
    },
    "schema_version": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/semverString"
    },
    "trace_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/traceId"
    },
    "problem_brief_ref": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
    },
    "knowledge_pool_assessment_ref": {
      "anyOf": [
        {
          "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
        },
        { "type": "null" }
      ]
    },
    "knowledge_pool_coverage": {
      "type": ["string", "null"],
      "enum": ["not_applicable", "none", "weak", "partial", "strong", null]
    },
    "knowledge_candidate_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "knowledge_role_context_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "knowledge_gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "knowledge_required": {
      "type": "boolean"
    },
    "response_control_ref": {
      "anyOf": [
        {
          "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
        },
        { "type": "null" }
      ]
    },
    "selected_knowledge_pool_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "selected_module_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "selected_technique_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "selected_theory_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "evidence_bundle_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "normalized_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system_of_interest"],
      "properties": {
        "system_of_interest": {
          "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "system_level": {
          "type": ["string", "null"]
        },
        "included": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string" }
        },
        "interfaces": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["objective_id", "statement", "metric", "verification_method"],
        "properties": {
          "objective_id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "statement": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "metric": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "verification_method": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "priority": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/priorityEnum"
          }
        }
      }
    },
    "verification_intent": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "criterion_id",
          "verification_method",
          "expected_evidence",
          "target_summary"
        ],
        "properties": {
          "criterion_id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "verification_method": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "expected_evidence": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "target_summary": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "status": {
            "type": "string",
            "enum": ["planned", "blocked", "satisfied"]
          }
        }
      }
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "description": { "type": "string" },
          "role": {
            "type": ["string", "null"],
            "enum": ["response", "controllable", "noise", "fixed", null]
          },
          "unit": { "type": ["string", "null"] },
          "bounds": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          },
          "source_artifact_ref": {
            "anyOf": [
              {
                "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
              },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement"],
        "properties": {
          "id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "statement": { "type": "string" },
          "kind": {
            "type": ["string", "null"],
            "enum": ["physical", "geometric", "regulatory", "economic", "other", null]
          },
          "source_artifact_ref": {
            "anyOf": [
              {
                "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
              },
              { "type": "null" }
            ]
          },
          "provenance_source": {
            "type": ["string", "null"]
          },
          "rationale": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "boundary_conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "description": { "type": "string" },
          "blocking": { "type": "boolean" }
        }
      }
    },
    "assumption_status": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assumption_id",
          "statement",
          "validation_intent",
          "status",
          "impact_if_false"
        ],
        "properties": {
          "assumption_id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "statement": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "validation_intent": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "validated", "waived"]
          },
          "blocking": { "type": "boolean" },
          "impact_if_false": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          }
        }
      }
    },
    "open_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["issue_id", "description", "category"],
        "properties": {
          "issue_id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "description": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "category": {
            "type": "string",
            "enum": ["missing_information", "assumption", "approval", "conflict", "staleness", "other"]
          },
          "blocking": { "type": "boolean" },
          "source_artifact_refs": {
            "type": "array",
            "items": {
              "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
            }
          }
        }
      }
    },
    "mechanism_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "name": { "type": "string" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "analysis_pathways": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary"],
        "properties": {
          "id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "summary": { "type": "string" }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["conflict_id", "description", "involved_artifact_refs", "resolution_status"],
        "properties": {
          "conflict_id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "description": { "type": "string" },
          "severity": {
            "type": ["string", "null"],
            "enum": ["low", "medium", "high", "critical", null]
          },
          "involved_artifact_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
            }
          },
          "resolution_status": {
            "type": "string",
            "enum": ["open", "escalated", "resolved", "waived"]
          },
          "resolution_notes": { "type": ["string", "null"] }
        }
      }
    },
    "staleness": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_ref", "reason"],
        "properties": {
          "artifact_ref": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
          },
          "invalid_after": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "reason": { "type": "string" }
        }
      }
    },
    "required_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "gate_type", "status", "rationale"],
        "properties": {
          "gate_id": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "gate_type": {
            "type": "string",
            "enum": ["clarification", "approval", "verification", "conflict", "staleness"]
          },
          "status": {
            "type": "string",
            "enum": ["PENDING", "SATISFIED", "WAIVED"]
          },
          "rationale": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          }
        }
      }
    },
    "ready_for_task_decomposition": {
      "type": "boolean"
    },
    "merge_policy_version": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "summary_for_routing": {
      "type": "string",
      "description": "Compressed digest for local orchestrator routing; not authoritative over structured fields."
    },
    "updated_at": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/iso8601Utc"
    }
  }
}
