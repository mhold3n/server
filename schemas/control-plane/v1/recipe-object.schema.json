{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/recipe-object.schema.json",
  "title": "recipe_object — task-class implementation recipe",
  "description": "For agents: the task-shaped execution recipe linked from one or more knowledge packs. Captures why a stack is used, what objects are touched, and how success is evaluated.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recipe_id",
    "schema_version",
    "title",
    "task_class",
    "assumptions",
    "why_this_stack",
    "knowledge_pack_ref",
    "touched_objects",
    "implementation_pattern",
    "required_inputs",
    "required_outputs",
    "failure_signatures",
    "acceptance_tests",
    "adapter_refs",
    "evidence_refs"
  ],
  "properties": {
    "recipe_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "title": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "task_class": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "why_this_stack": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "knowledge_pack_ref": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
    },
    "touched_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role"],
        "properties": {
          "name": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "role": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "notes": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "implementation_pattern": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "required_inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failure_signatures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_tests": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "adapter_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    }
  }
}
