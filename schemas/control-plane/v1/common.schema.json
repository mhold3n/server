{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/common.schema.json",
  "title": "Control plane v1 — shared definitions",
  "description": "For agents: reusable primitives and enums referenced by task packets, artifact envelopes, and orchestration artifacts. All persisted cross-refs use absolute $id URIs in schemas; instance refs use artifact:// URIs.",
  "$defs": {
    "semverString": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version for contract payloads (e.g. 1.0.0)."
    },
    "uuidString": {
      "type": "string",
      "format": "uuid"
    },
    "iso8601Utc": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp; prefer Z suffix for UTC."
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "artifactRef": {
      "type": "string",
      "pattern": "^artifact://.+",
      "description": "Logical reference to a persisted artifact (typed envelope or blob)."
    },
    "traceId": {
      "type": "string",
      "minLength": 8,
      "description": "Correlation id spanning one engineer-facing session run (uuid or ulid)."
    },
    "sha256Hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "scopeObject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "included": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "default": { "included": [], "excluded": [] }
    },
    "unitSystemEnum": {
      "type": "string",
      "enum": ["SI", "US_CUSTOMARY", "MIXED_DECLARED"]
    },
    "knowledgeModuleClassEnum": {
      "type": "string",
      "enum": [
        "application",
        "framework",
        "integration_layer",
        "runtime_kernel",
        "translator",
        "standard"
      ]
    },
    "deliveryKindEnum": {
      "type": "string",
      "enum": ["docker_image", "uv_venv", "dotnet_toolchain", "host_app"]
    },
    "quantifiedScalar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": { "type": "number" },
        "unit": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "priorityEnum": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "taskPacketStatusEnum": {
      "type": "string",
      "enum": ["PENDING", "RUNNING", "BLOCKED", "COMPLETED", "FAILED", "CANCELLED"]
    },
    "taskTypeEnum": {
      "type": "string",
      "enum": [
        "CODEGEN",
        "TRANSFORM",
        "VALIDATION_CODE",
        "MULTIMODAL_EXTRACTION",
        "RESEARCH_SYNTHESIS",
        "VALIDATION",
        "ESCALATION_REVIEW"
      ]
    },
    "executorEnum": {
      "type": "string",
      "enum": [
        "local_general_model",
        "coding_model",
        "multimodal_model",
        "strategic_reviewer",
        "deterministic_validator"
      ]
    },
    "artifactTypeEnum": {
      "type": "string",
      "enum": [
        "RESPONSE_MODE",
        "RESPONSE_CONTROL_ASSESSMENT",
        "KNOWLEDGE_POOL",
        "KNOWLEDGE_POOL_ASSESSMENT",
        "KNOWLEDGE_PACK",
        "MODULE_CARD",
        "TECHNIQUE_CARD",
        "THEORY_CARD",
        "RECIPE_OBJECT",
        "EXECUTION_ADAPTER_SPEC",
        "EVIDENCE_BUNDLE",
        "ROLE_CONTEXT_BUNDLE",
        "ENVIRONMENT_SPEC",
        "GUI_SESSION_SPEC",
        "PROBLEM_BRIEF",
        "REQUIREMENTS_SET",
        "CONSTRAINTS_REGISTER",
        "ASSUMPTIONS_REGISTER",
        "RESEARCH_DIGEST",
        "CLAIMS_REGISTRY",
        "SOURCE_INDEX",
        "DOCUMENT_EXTRACT",
        "VARIABLES_REGISTER",
        "BOUNDARY_CONDITIONS",
        "CANDIDATE_MODELS",
        "ANALYSIS_PLAN",
        "DOE_PLAN",
        "TASK_PACKET",
        "CODE_PATCH",
        "PARSER_OUTPUT",
        "SIMULATION_RESULT",
        "VERIFICATION_REPORT",
        "DECISION_LOG",
        "COST_LOG",
        "ESCALATION_RECORD",
        "APPROVAL_RECORD",
        "ENGINEERING_STATE",
        "TASK_QUEUE",
        "ROUTING_POLICY"
      ]
    },
    "artifactStatusEnum": {
      "type": "string",
      "enum": ["ACTIVE", "SUPERSEDED", "INVALIDATED", "ARCHIVED"]
    },
    "artifactValidationStateEnum": {
      "type": "string",
      "enum": ["PENDING", "VALID", "INVALID", "WAIVED"]
    },
    "verificationOutcomeEnum": {
      "type": "string",
      "enum": ["PASS", "REWORK", "ESCALATE"]
    },
    "escalationReasonEnum": {
      "type": "string",
      "enum": ["AMBIGUITY", "CONFLICT", "COMPLEXITY", "HIGH_IMPACT_REVIEW"]
    },
    "producerObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "executor"],
      "properties": {
        "component": { "$ref": "#/$defs/nonEmptyString" },
        "executor": { "type": "string", "minLength": 1 },
        "run_id": { "type": ["string", "null"] },
        "task_packet_id": { "type": ["string", "null"] }
      }
    },
    "budgetPolicyObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allow_escalation"],
      "properties": {
        "allow_escalation": { "type": "boolean" },
        "max_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "max_cost_usd": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "routingMetadataObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_by",
        "selected_executor",
        "reason",
        "router_policy_version"
      ],
      "properties": {
        "requested_by": { "$ref": "#/$defs/nonEmptyString" },
        "selected_executor": { "$ref": "#/$defs/executorEnum" },
        "reason": { "$ref": "#/$defs/nonEmptyString" },
        "router_policy_version": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "provenanceObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_stage"],
      "properties": {
        "source_stage": { "$ref": "#/$defs/nonEmptyString" },
        "parent_task_packet_id": { "type": ["string", "null"] },
        "decision_log_ref": { "type": ["string", "null"] }
      }
    },
    "requiredOutputSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "schema_version"],
      "properties": {
        "artifact_type": { "$ref": "#/$defs/artifactTypeEnum" },
        "schema_version": { "$ref": "#/$defs/semverString" }
      }
    },
    "contractErrorDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "message"],
      "properties": {
        "path": { "type": "string" },
        "message": { "$ref": "#/$defs/nonEmptyString" },
        "keyword": { "type": ["string", "null"] }
      }
    }
  }
}
