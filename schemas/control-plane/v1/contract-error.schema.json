{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/contract-error.schema.json",
  "title": "contract_error — structured validation failure envelope",
  "description": "For agents: returned by API validators; aligns with ContractValidationError.to_envelope().",
  "type": "object",
  "additionalProperties": false,
  "required": ["error_code", "contract_type", "schema_id", "details"],
  "properties": {
    "error_code": {
      "type": "string",
      "enum": [
        "SCHEMA_VALIDATION_FAILED",
        "LIFECYCLE_VIOLATION",
        "PROVENANCE_VIOLATION",
        "VERSION_INCOMPATIBLE",
        "LEGACY_FORBIDDEN"
      ]
    },
    "contract_type": {
      "type": "string",
      "minLength": 1
    },
    "schema_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": { "type": ["string", "null"] },
    "details": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/contractErrorDetail"
      }
    }
  }
}
