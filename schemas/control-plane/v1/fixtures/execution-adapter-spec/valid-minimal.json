{
  "adapter_spec_id": "openfoam_default",
  "schema_version": "1.0.0",
  "tool_id": "openfoam",
  "supported_library_version": "current-curated",
  "knowledge_pack_ref": "artifact://knowledge-pack/openfoam",
  "preferred_environment_ref": "artifact://environment-spec/eng_cfd_docker",
  "environment_refs": [
    "artifact://environment-spec/eng_cfd_docker",
    "artifact://environment-spec/eng_cfd_uv"
  ],
  "callable_interface": {
    "kind": "cli",
    "entrypoint": "python -m tools.openfoam_adapter",
    "signature": "run(case_dir: str, solver: str)"
  },
  "typed_inputs": [
    { "name": "case_dir", "type": "path", "required": true, "unit": null }
  ],
  "typed_outputs": [
    { "name": "result_dir", "type": "path", "unit": null }
  ],
  "unit_policy": {
    "unit_system": "SI",
    "require_declared_units": true,
    "notes": "Declare boundary-condition units before execution."
  },
  "file_translators": [
    { "from": "STEP", "to": "OpenFOAM polyMesh", "notes": "Usually via gmsh/snappyHexMesh" }
  ],
  "runtime_requirements": ["OpenFOAM environment sourced"],
  "healthcheck_refs": ["artifact://verification-report/eng_cfd_uv"],
  "safety_limits": ["Refuse execution when case dictionaries are missing"],
  "emitted_artifact_refs": ["artifact://simulation-result/openfoam/default"],
  "launcher_ref": "knowledge/coding-tools/runtime/launchers/eng-cfd.sh"
}
