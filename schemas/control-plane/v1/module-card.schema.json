{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/module-card.schema.json",
  "title": "module_card — selected asset across tools, packages, and knowledge banks",
  "description": "For agents: modules are the internal assets chosen after pool selection. Technique cards are derived from selected modules.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "module_card_id",
    "schema_version",
    "module_key",
    "module_kind",
    "label",
    "summary",
    "pool_refs",
    "technique_refs"
  ],
  "properties": {
    "module_card_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "module_key": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "module_kind": {
      "type": "string",
      "enum": ["tool", "package", "knowledge_bank"]
    },
    "label": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "summary": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pool_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "technique_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "legacy_knowledge_pack_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    }
  }
}
