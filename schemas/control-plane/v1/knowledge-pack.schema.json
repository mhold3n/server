{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://birtha.local/schemas/control-plane/v1/knowledge-pack.schema.json",
  "title": "knowledge_pack — canonical tool expertise artifact",
  "description": "For agents: the shared external knowledge substrate for one engineering coding tool or integration layer. Encodes capability boundaries, affordances, linked recipes, and linked evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "knowledge_pack_id",
    "schema_version",
    "tool_id",
    "tool_name",
    "module_class",
    "library_version",
    "bindings",
    "scope",
    "core_objects",
    "best_for",
    "anti_patterns",
    "interfaces",
    "integration_refs",
    "recipe_refs",
    "adapter_refs",
    "evidence_refs",
    "minutes_source_refs",
    "environment_refs",
    "provenance"
  ],
  "properties": {
    "knowledge_pack_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "tool_id": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "tool_name": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "module_class": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/knowledgeModuleClassEnum"
    },
    "library_version": {
      "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["solves", "not_for"],
      "properties": {
        "solves": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "not_for": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "core_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "role"],
        "properties": {
          "name": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "kind": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "role": {
            "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/nonEmptyString"
          }
        }
      }
    },
    "best_for": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "anti_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "interfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputs", "outputs"],
      "properties": {
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "integration_refs": {
      "type": "array",
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "recipe_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "adapter_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "minutes_source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "environment_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://birtha.local/schemas/control-plane/v1/common.schema.json#/$defs/artifactRef"
      }
    },
    "alias_names": {
      "type": "array",
      "items": { "type": "string" }
    },
    "substitution_note": {
      "type": ["string", "null"]
    },
    "excluded_reason": {
      "type": ["string", "null"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "examples": {
          "type": "array",
          "items": { "type": "string" }
        },
        "benchmarks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
