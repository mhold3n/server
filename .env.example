# Global environment example for local/dev and server stacks

# Core service settings
DEBUG=true
LOG_LEVEL=INFO
TZ=UTC
PUID=1000
PGID=1000

# API <-> Worker connectivity
# For local dev without TLS, point to worker port 8000
OPENAI_BASE_URL=http://worker.local:8000/v1
OPENAI_API_KEY=local-dev-token

# Redis and observability ports (override if needed)
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# MCP servers
GITHUB_TOKEN=replace-with-your-token
GITHUB_OWNER=your-owner-or-org

# Secrets MCP (Vault dev mode by default)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Vector DB MCP
QDRANT_URL=http://qdrant:6333

# Optional: Pi-hole
PIHOLE_PASSWORD=admin
PIHOLE_UPSTREAM_DNS=1.1.1.1

# Optional: AdGuard Home (do not run with Pi-hole simultaneously)
ADGUARD_ADMIN_PASSWORD=admin

# Optional: WireGuard (server stack)
SERVER_PUBLIC_HOST=server.local
WG_PORT=51820

# Worker gateway
WORKER_VLLM_PORT=8000
WORKER_PROXY_PORT=8443

# AI runtime routing
LLM_BACKEND=mock
LLM_RUNNER_URL=http://worker.local:11434
OLLAMA_MODEL=llama3:8b-instruct
VLLM_MODEL=Qwen/Qwen3.5-9B
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
HF_INFERENCE_MODEL=Qwen/Qwen3-8B
HF_INFERENCE_BASE_URL=https://router.huggingface.co/v1
MODEL_RUNTIME_URL=http://model-runtime:8000
MODEL_RUNTIME_PORT=8765
MOCK_INFER=1

# AI runtime images are pinned by digest by default; override only intentionally.
VLLM_IMAGE=vllm/vllm-openai@sha256:7a0f0fdd2771464b6976625c2b2d5dd46f566aa00fbc53eceab86ef50883da90
OLLAMA_IMAGE=ollama/ollama@sha256:1375516e575632dd84ad23b2c1cbd5e36ef34ebe8e41f9857545ab9aa72aeec2

# RAG embeddings/reranking
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BACKEND=auto
EMBEDDING_ENDPOINT_URL=
RERANKER_URL=

# Search
MEILI_MASTER_KEY=change-me
SEARXNG_BASE_URL=http://localhost:8083/
SEARXNG_SECRET_KEY=change-me

# Authentik (SSO)
AUTHENTIK_SECRET_KEY=replace-with-random-32b
AUTHENTIK_POSTGRES_PASSWORD=change-me
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_DB=authentik

# Nextcloud
NEXTCLOUD_DB_ROOT_PASSWORD=change-me
NEXTCLOUD_DB_PASSWORD=change-me

# Immich
IMMICH_DB_PASSWORD=change-me

# Vikunja
VIKUNJA_DB_PASSWORD=change-me
VIKUNJA_PUBLIC_URL=http://localhost:8088

# AnonAddy
ANONADDY_APP_KEY=base64:replace-with-app-key
ANONADDY_DB_ROOT_PASSWORD=change-me
ANONADDY_DB_PASSWORD=change-me

# Tailscale
TAILSCALE_AUTHKEY=tskey-...
TAILSCALE_HOSTNAME=agent-server

# Mullvad via Gluetun
MULLVAD_WG_PRIVATE_KEY=
MULLVAD_WG_ADDRESS=
MULLVAD_SERVER_CITIES=

# Notes:
# - For server deployment, you can also copy server-config/env.server.template to .env
# - For workstation, see workstation-config/env.workstation for starting points
