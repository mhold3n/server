# Global environment example for local/dev and server stacks

# Host directory for all Compose-managed durable volumes (default: .docker-data/ in repo).
# Set to a removable drive or shared path for portability, e.g.:
#   macOS:   COMPOSE_DATA_ROOT=/Volumes/ESD-USB/server-docker-data
#   Linux:   COMPOSE_DATA_ROOT=/mnt/esd/server-docker-data
#   Windows: COMPOSE_DATA_ROOT=D:/server-docker-data   (forward slashes recommended)
# Production Linux layouts that used /mnt/appdata: COMPOSE_DATA_ROOT=/mnt/appdata
# COMPOSE_DATA_ROOT=.docker-data

# Local dev caches (uv, npm tarball cache, Hugging Face weights, tool venvs).
# Defaults are applied when you `source scripts/workspace_env.sh` (see scripts/cache_env.sh).
# Set CACHE_ROOT to a large disk to colocate everything, e.g. CACHE_ROOT=/Volumes/FastDisk/server-cache
# CACHE_ROOT=
# UV_CACHE_DIR=          # default: $CACHE_ROOT/uv
# NPM_CONFIG_CACHE=      # default: $CACHE_ROOT/npm  (npm also reads npm_config_cache)
# HF_HOME=               # default: $CACHE_ROOT/models/hf

# Core service settings
DEBUG=true
LOG_LEVEL=INFO
TZ=UTC
PUID=1000
PGID=1000

# API <-> Worker connectivity
# Default docker-compose.yml uses in-stack mock-openai (see service mock-openai); host port 18002.
# For local dev without TLS, point to worker port 8000 or override to your OpenAI-compatible URL.
OPENAI_BASE_URL=http://worker.local:8000/v1
OPENAI_API_KEY=local-dev-token
# MOCK_OPENAI_PORT=18002

# Redis and observability ports (override if needed)
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# MCP servers
GITHUB_TOKEN=replace-with-your-token
GITHUB_OWNER=your-owner-or-org

# Secrets MCP (Vault dev mode by default)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Vector DB MCP
QDRANT_URL=http://qdrant:6333

# Optional: Pi-hole
PIHOLE_PASSWORD=admin
PIHOLE_UPSTREAM_DNS=1.1.1.1

# Optional: AdGuard Home (do not run with Pi-hole simultaneously)
ADGUARD_ADMIN_PASSWORD=admin

# Optional: WireGuard (server stack)
SERVER_PUBLIC_HOST=server.local
WG_PORT=51820

# Worker gateway
WORKER_VLLM_PORT=8000
WORKER_PROXY_PORT=8443

# API control plane → TypeScript agent-platform (OrchestratorClient, workflow execute).
# Pydantic accepts either variable name for the same setting (see services/api-service/src/config.py).
# AGENT_PLATFORM_URL=http://wrkhrs-agent-platform:8000
# ORCHESTRATOR_AGENT_PLATFORM_URL=http://wrkhrs-agent-platform:8000

# Agent-platform → API control plane + DevPlane HTTP callbacks (must be reachable from the agent-platform container).
# ORCHESTRATOR_API_URL=http://api:8080
# DEVPLANE_PUBLIC_BASE_URL=http://api:8080

# API → agent-platform for DevPlane backend runs (DevPlaneExecutionClient).
# AGENT_PLATFORM_URL=http://wrkhrs-agent-platform:8000

# AI runtime routing
LLM_BACKEND=mock
LLM_RUNNER_URL=http://worker.local:11434
OLLAMA_MODEL=llama3:8b-instruct
OLLAMA_MODEL_TINY=
OLLAMA_MODEL_SMALL=
OLLAMA_MODEL_MEDIUM=
OLLAMA_MODEL_LARGE=
VLLM_MODEL=Qwen/Qwen3.5-9B
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
HF_INFERENCE_MODEL=Qwen/Qwen3-8B
HF_INFERENCE_BASE_URL=https://router.huggingface.co/v1
MODEL_RUNTIME_URL=http://model-runtime:8000
MODEL_RUNTIME_PORT=8765
MOCK_INFER=1

# macOS host memory governor (used to gate Ollama inside Docker)
HOST_MEMORY_GOVERNOR_URL=http://host.docker.internal:8766
HOST_MEMORY_GOVERNOR_TOKEN=

# AI runtime images are pinned by digest by default; override only intentionally.
VLLM_IMAGE=vllm/vllm-openai@sha256:7a0f0fdd2771464b6976625c2b2d5dd46f566aa00fbc53eceab86ef50883da90
OLLAMA_IMAGE=ollama/ollama@sha256:1375516e575632dd84ad23b2c1cbd5e36ef34ebe8e41f9857545ab9aa72aeec2

# RAG embeddings/reranking
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BACKEND=auto
EMBEDDING_ENDPOINT_URL=
RERANKER_URL=

# Search
MEILI_MASTER_KEY=change-me
SEARXNG_BASE_URL=http://localhost:8083/
SEARXNG_SECRET_KEY=change-me

# Authentik (SSO)
AUTHENTIK_SECRET_KEY=replace-with-random-32b
AUTHENTIK_POSTGRES_PASSWORD=change-me
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_DB=authentik

# Nextcloud
NEXTCLOUD_DB_ROOT_PASSWORD=change-me
NEXTCLOUD_DB_PASSWORD=change-me

# Immich
IMMICH_DB_PASSWORD=change-me

# Vikunja
VIKUNJA_DB_PASSWORD=change-me
VIKUNJA_PUBLIC_URL=http://localhost:8088

# AnonAddy
ANONADDY_APP_KEY=base64:replace-with-app-key
ANONADDY_DB_ROOT_PASSWORD=change-me
ANONADDY_DB_PASSWORD=change-me

# Tailscale
TAILSCALE_AUTHKEY=tskey-...
TAILSCALE_HOSTNAME=agent-server

# Mullvad via Gluetun
MULLVAD_WG_PRIVATE_KEY=
MULLVAD_WG_ADDRESS=
MULLVAD_SERVER_CITIES=

# Notes:
# - For server deployment, you can also copy server-config/env.server.template to .env
# - For workstation, see workstation-config/env.workstation for starting points
